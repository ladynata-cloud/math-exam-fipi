# Apache rewrite rules for SPA on shared hosting (cPanel, ISPmanager, etc.).
# Copy this to .htaccess in the same folder as index.html.
#
# Currently the trainer uses HashRouter (URLs like /#/task/123), which works
# WITHOUT this file. Use this file only if you switch to BrowserRouter for
# cleaner URLs (/task/123 instead of /#/task/123).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Don't rewrite real files or directories.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Send everything else to index.html for client routing.
  RewriteRule ^ index.html [L]
</IfModule>

# Compress text assets if mod_deflate is available
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache hashed assets aggressively
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css              "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
  ExpiresByType font/woff2            "access plus 1 year"
</IfModule>
